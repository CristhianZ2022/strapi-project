{
  "kind": "collectionType",
  "collectionName": "clientes",
  "info": {
    "singularName": "cliente",
    "pluralName": "clientes",
    "displayName": "clientes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nombres": {
      "type": "string"
    },
    "apellidos": {
      "type": "string"
    },
    "identificacion": {
      "type": "string",
      "minLength": 8,
      "maxLength": 13
    },
    "contrato": {
      "type": "biginteger"
    },
    "ciudad": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "telefono": {
      "type": "biginteger"
    },
    "estado": {
      "type": "enumeration",
      "enum": [
        "ACTIVO",
        "CORTADO",
        "SUSPENDIDO",
        "TERMINADO"
      ]
    },
    "valores": {
      "type": "decimal"
    },
    "plans": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::plan.plan"
    },
    "tipoCliente": {
      "type": "string"
    },
    "tipoPlan": {
      "type": "string"
    },
    "reference": {
      "type": "component",
      "component": "component.references",
      "repeatable": true
    },
    "currentAge": {
      "type": "date"
    },
    "planPrincipal": {
      "type": "boolean",
      "default": false
    },
    "automaticCut": {
      "type": "boolean",
      "default": true
    },
    "discountLaw": {
      "type": "component",
      "component": "component.discount-law",
      "repeatable": false
    },
    "withholdingAgent": {
      "type": "boolean",
      "default": false
    },
    "files": {
      "type": "component",
      "component": "component.file",
      "repeatable": true
    },
    "automaticInvoice": {
      "type": "boolean",
      "default": true
    },
    "contact": {
      "type": "component",
      "component": "component.contact",
      "repeatable": false
    },
    "entity": {
      "type": "enumeration",
      "enum": [
        "PUBLICA",
        "PRIVADA"
      ]
    },
    "applied_discount": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::applied-discount.applied-discount"
    }
  }
}
